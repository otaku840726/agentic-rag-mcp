# Qdrant Vector Database
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=your-collection-name

# Provider API Keys (only configure what you use)
OPENAI_API_KEY=your-openai-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key
# GEMINI_API_KEY=your-gemini-api-key
# LOCAL_LLM_URL=http://127.0.0.1:1234/v1
# LOCAL_LLM_API_KEY=your-local-api-key

# Component provider/model overrides (default: openai + gpt-4o-mini)
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_MAX_TOKENS=8191
# PLANNER_PROVIDER=local
# PLANNER_MODEL=qwen2.5-coder-14b
# SYNTHESIZER_PROVIDER=openai
# SYNTHESIZER_MODEL=gpt-4o-mini
# JUDGE_PROVIDER=openai
# JUDGE_MODEL=gpt-4o-mini
